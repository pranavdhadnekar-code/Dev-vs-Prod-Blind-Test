# Copy to .env and fill in values (never commit .env)
# The arena needs the ANCHOR (Falcon 2) + at least one competitor with a
# shared language before any battles can run.

# --- Anchor: Falcon 2 via Murf FALCON API (required) ---
# Dev stream (this repo default for Falcon 2 / omni_tts):
OMNI_API_KEY=
MURF_FALCON_URL=https://global.api.dev.murf.ai/v1/speech/stream
# Production Falcon 2 (omit MURF_FALCON_URL; use a prod-valid ap2_ key):
# OMNI_API_KEY=
# default URL: https://api.murf.ai/v1/speech/stream

# --- Competitors (configure any subset; only configured ones are scheduled) ---
# Each vendor below is its single best model:
#   Murf -> Gen 2 | ElevenLabs -> Flash 2.5 | Deepgram -> Aura 2 | Cartesia -> Sonic 3.5 | Sarvam -> Bulbul v3
MURF_API_KEY=
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
SARVAM_API_KEY=
# OpenAI key powers both the OpenAI TTS competitor and the comment summaries
OPENAI_API_KEY=

# --- New providers ---
# Google Cloud TTS (REST API key; enable the Text-to-Speech API on your project)
GOOGLE_TTS_API_KEY=
# Microsoft Azure TTS (Speech resource): both key and region are required
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# Amazon Polly (uses standard AWS credentials via boto3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Optional arena configuration ---
# ARENA_ANCHOR — provider pinned to strength 0; all battles are anchor vs competitors.
# Valid IDs (must match config.TTS_PROVIDERS):
#   omni_tts          Falcon 2 / Murf FALCON (default)
#   murf_gen2         Murf Gen 2
#   elevenlabs_v3     ElevenLabs Flash 2.5
#   deepgram_aura2    Deepgram Aura 2
#   cartesia_sonic3   Cartesia Sonic 3.5
#   openai            OpenAI
#   sarvam_bulbul_v3  Sarvam Bulbul v3
#   google_tts        Google Cloud TTS
#   azure_tts         Azure TTS
#   amazon_polly      Amazon Polly
# ARENA_ANCHOR=omni_tts
# Pairing strategy: anchor_only (default) | anchor_plus | all_vs_all
# ARENA_PAIRING_STRATEGY=anchor_only

# --- Deployment (optional) ---
# Persist votes on a mounted volume in cloud hosts (Fly.io, Docker, etc.)
# DATABASE_PATH=/data/benchmark_data.db
#
# For a SHARED leaderboard on Streamlit Community Cloud (or any host with an
# ephemeral disk), point the app at a managed Postgres (e.g. Neon free tier).
# When DATABASE_URL is set it OVERRIDES SQLite and every vote persists there.
# Get this from the Neon dashboard ("Connection string", pooled, with sslmode).
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
