# Copy to .env and fill in values (never commit .env)
# Blind Falcon dev vs Falcon prod — both endpoints required.

# --- Falcon dev stream (competitor when prod is anchor) ---
FALCON_DEV_API_KEY=
# Or legacy name:
# OMNI_API_KEY=
FALCON_DEV_URL=https://api.dev.murf.ai/v1/speech/stream
# Or legacy name:
# MURF_FALCON_URL=https://api.dev.murf.ai/v1/speech/stream
# Dev stream is often slow; health probes default to 180s (override if needed):
# FALCON_DEV_HEALTH_TIMEOUT=180
# FALCON_DEV_TIMEOUT=180

# --- Falcon production (default anchor / reference) ---
FALCON_PROD_API_KEY=
# Or legacy name:
# MURF_API_KEY=
# FALCON_PROD_URL=https://api.murf.ai/v1/speech/stream

# --- Optional: OpenAI key for comment summaries in the UI (not TTS) ---
# OPENAI_API_KEY=

# --- Optional arena configuration ---
# ARENA_ANCHOR — pinned to strength 0 (default: falcon_prod)
# Valid IDs: falcon_prod | falcon_dev
# Legacy: omni_tts -> falcon_dev, murf_gen2 -> falcon_prod
# ARENA_ANCHOR=falcon_prod
# ARENA_PAIRING_STRATEGY=anchor_only

# --- Deployment (optional) ---
# DATABASE_PATH=/data/benchmark_data.db
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
