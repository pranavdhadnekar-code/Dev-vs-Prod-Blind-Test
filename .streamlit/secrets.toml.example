# Streamlit Community Cloud — paste into App → Settings → Secrets
# (Do not commit the real secrets.toml; only this example.)

DATABASE_URL = "postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

FALCON_DEV_API_KEY = "ap2_your_dev_key"
FALCON_DEV_URL = "https://api.dev.murf.ai/v1/speech/stream"

FALCON_PROD_API_KEY = "ap2_your_prod_key"
FALCON_PROD_URL = "https://global.api.murf.ai/v1/speech/stream"

# Optional
ARENA_ANCHOR = "falcon_prod"
