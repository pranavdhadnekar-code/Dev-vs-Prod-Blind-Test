# Streamlit Community Cloud secrets template.
# Copy these keys into your app's "Settings -> Secrets" panel (do NOT commit the
# real file). Streamlit exposes top-level keys here as environment variables,
# so the app picks up DATABASE_URL automatically.

# --- Shared persistent storage (Neon Postgres) ---
# Required for a shared leaderboard on Streamlit Cloud. Without it the app falls
# back to a local SQLite file that is WIPED on every redeploy/restart.
DATABASE_URL = "postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# --- Anchor: Falcon 2 (required) ---
OMNI_API_KEY = ""
MURF_FALCON_URL = "https://api.dev.murf.ai/v1/speech/stream"
MURF_FALCON_REDIS_STREAM = "BLUE"

# --- Competitors (configure any subset) ---
MURF_API_KEY = ""
ELEVENLABS_API_KEY = ""
DEEPGRAM_API_KEY = ""
CARTESIA_API_KEY = ""
SARVAM_API_KEY = ""
OPENAI_API_KEY = ""
GOOGLE_TTS_API_KEY = ""
AZURE_SPEECH_KEY = ""
AZURE_SPEECH_REGION = ""
AWS_ACCESS_KEY_ID = ""
AWS_SECRET_ACCESS_KEY = ""
AWS_REGION = "us-east-1"
